rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document: global
    // Fields: siteName, slogan, heroDescription, primaryColor, contactEmail, instagramUrl, kakaoUrl
    // 
    // Collection: portfolio
    // Document ID: auto
    // Fields: title, category, imageUrl, description, createdAt
    //
    // Collection: posts
    // Document ID: auto
    // Fields: title, content, imageUrl, author, createdAt
    //
    // Collection: inquiries
    // Document ID: auto
    // Fields: name, email, message, status, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ipigg351@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Settings
    match /settings/global {
      allow read: if true; // Explicitly public for SEO and branding
      allow write: if isAdmin();
    }

    // Portfolio
    match /portfolio/{itemId} {
      allow read: if true; // Public portfolio
      allow create: if isAdmin() && 
        isValidString(request.resource.data.title, 100) &&
        request.resource.data.category in ["Logo", "Website", "Branding", "UI/UX"] &&
        isValidUrl(request.resource.data.imageUrl);
      allow update: if isAdmin() && 
        isValidString(request.resource.data.title, 100) &&
        request.resource.data.category in ["Logo", "Website", "Branding", "UI/UX"] &&
        isValidUrl(request.resource.data.imageUrl);
      allow delete: if isAdmin();
    }

    // Blog Posts
    match /posts/{postId} {
      allow read: if true; // Public blog
      allow create: if isAdmin() &&
        isValidString(request.resource.data.title, 200) &&
        isValidString(request.resource.data.content, 10000);
      allow update: if isAdmin() &&
        isValidString(request.resource.data.title, 200) &&
        isValidString(request.resource.data.content, 10000);
      allow delete: if isAdmin();
    }

    // Inquiries
    match /inquiries/{inquiryId} {
      allow create: if true; // Anyone can submit an inquiry
      allow read, update, delete: if isAdmin();
    }

    // User profiles (Admin state)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
